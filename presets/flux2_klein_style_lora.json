{
  "job": "extension",
  "config": {
    "name": "preset",
    "process": [
      {
        "type": "diffusion_trainer",
        "training_folder": "output",
        "device": "cuda",
        "trigger_word": null,
        "network": {
          "type": "lora",
          "linear": 32,
          "linear_alpha": 32
        },
        "save": {
          "dtype": "bf16",
          "save_every": 250,
          "max_step_saves_to_keep": 4,
          "save_format": "safetensors",
          "push_to_hub": false
        },
        "datasets": [
          {
            "folder_path": "/path/to/images/folder",
            "caption_ext": "txt",
            "caption_dropout_rate": 0.05,
            "resolution": [
              768,
              1024
            ],
            "num_repeats": 1,
            "cache_latents_to_disk": true
          }
        ],
        "train": {
          "batch_size": 1,
          "steps": 2500,
          "gradient_accumulation": 1,
          "train_unet": true,
          "train_text_encoder": false,
          "gradient_checkpointing": true,
          "noise_scheduler": "flowmatch",
          "optimizer": "adamw8bit",
          "timestep_type": "weighted",
          "content_or_style": "style",
          "lr": 0.0001,
          "dtype": "bf16"
        },
        "model": {
          "name_or_path": "black-forest-labs/FLUX.2-klein-base-4B",
          "arch": "flux2_klein_4b",
          "quantize": true,
          "qtype": "qfloat8",
          "quantize_te": true,
          "qtype_te": "qfloat8",
          "low_vram": true
        },
        "sample": {
          "sampler": "flowmatch",
          "sample_every": 250,
          "width": 1024,
          "height": 1024,
          "guidance_scale": 4,
          "sample_steps": 25
        }
      }
    ]
  },
  "meta": {
    "name": "[name]",
    "version": "1.0",
    "description": "Style LoRA on FLUX.2 Klein 4B (gated on HF). UNVERIFIED: ported from LDS's built-in (rank 32 = community style step-up from the 16 default; weighted timesteps = Klein arch canonical). Content-only captions, no trigger. Steps: LDS computes 50/image clamped [1200,3000]. For the 9B: arch flux2_klein_9b + the -9B path."
  }
}
