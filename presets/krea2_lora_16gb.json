{
  "job": "extension",
  "config": {
    "name": "preset",
    "process": [
      {
        "type": "diffusion_trainer",
        "training_folder": "output",
        "device": "cuda",
        "trigger_word": null,
        "network": {
          "type": "lora",
          "linear": 32,
          "linear_alpha": 32,
          "network_kwargs": {
            "ignore_if_contains": []
          }
        },
        "save": {
          "dtype": "bf16",
          "save_every": 250,
          "max_step_saves_to_keep": 4,
          "save_format": "diffusers",
          "push_to_hub": false
        },
        "datasets": [
          {
            "folder_path": "/path/to/images/folder",
            "caption_ext": "txt",
            "caption_dropout_rate": 0.05,
            "resolution": [512],
            "num_repeats": 1,
            "cache_latents_to_disk": false
          }
        ],
        "train": {
          "batch_size": 1,
          "steps": 2000,
          "gradient_accumulation": 1,
          "train_unet": true,
          "train_text_encoder": false,
          "gradient_checkpointing": true,
          "noise_scheduler": "flowmatch",
          "optimizer": "automagic3",
          "timestep_type": "sigmoid",
          "content_or_style": "balanced",
          "optimizer_params": {
            "weight_decay": 0.0001,
            "min_lr": 0.000001,
            "max_lr": 0.0001
          },
          "unload_text_encoder": true,
          "cache_text_embeddings": false,
          "lr": 0.0001,
          "disable_sampling": true,
          "dtype": "bf16",
          "loss_type": "mse"
        },
        "model": {
          "name_or_path": "krea/Krea-2-Raw",
          "arch": "krea2",
          "quantize": true,
          "qtype": "qfloat8",
          "quantize_te": true,
          "qtype_te": "qfloat8",
          "low_vram": true,
          "compile": false,
          "layer_offloading": true,
          "layer_offloading_text_encoder_percent": 1,
          "layer_offloading_transformer_percent": 0.35
        },
        "sample": {
          "sampler": "flowmatch",
          "sample_every": 250,
          "width": 1024,
          "height": 1024,
          "guidance_scale": 4,
          "sample_steps": 30
        }
      }
    ]
  },
  "meta": {
    "name": "[name]",
    "version": "1.1",
    "description": "LoRA on Krea 2 (raw) for 16GB+ cards: qfloat8 on transformer + TE, low_vram, layer offloading (35% transformer, 100% TE), TE unloaded after encoding, 512 training resolution, Automagic3 optimizer (adaptive per-group LR, weight decay 1e-4), sigmoid timesteps. v1.1 bounds the Automagic3 controller with min_lr 1e-6 / max_lr 1e-4 (the preset's own start LR is the ceiling; the controller self-adapts downward from it) — the source config predates upstream's 2026-07-17 runaway-LR fix, whose default bounds are only numerical overflow guards, not practical limits. Sampling is disabled by default to avoid VRAM spikes — re-enable it (or sample at 512) if you want previews. Community-sourced profile; for roomier cards use the krea2_lora_low_vram (24GB) preset instead."
  }
}
