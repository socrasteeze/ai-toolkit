{
  "job": "extension",
  "config": {
    "name": "preset",
    "process": [
      {
        "type": "diffusion_trainer",
        "training_folder": "output",
        "device": "cuda",
        "trigger_word": null,
        "network": {
          "type": "lora",
          "linear": 32,
          "linear_alpha": 32
        },
        "save": {
          "dtype": "bf16",
          "save_every": 250,
          "max_step_saves_to_keep": 4,
          "save_format": "safetensors",
          "push_to_hub": false
        },
        "datasets": [
          {
            "folder_path": "/path/to/images/folder",
            "caption_ext": "txt",
            "caption_dropout_rate": 0.05,
            "resolution": [1024],
            "num_repeats": 1,
            "cache_latents_to_disk": true
          }
        ],
        "train": {
          "batch_size": 1,
          "steps": 2000,
          "gradient_accumulation": 1,
          "train_unet": true,
          "train_text_encoder": false,
          "gradient_checkpointing": true,
          "noise_scheduler": "flowmatch",
          "optimizer": "adamw8bit",
          "timestep_type": "linear",
          "content_or_style": "balanced",
          "lr": 0.0001,
          "dtype": "bf16"
        },
        "model": {
          "name_or_path": "krea/Krea-2-Raw",
          "arch": "krea2",
          "quantize": true,
          "qtype": "qfloat8",
          "quantize_te": true,
          "qtype_te": "qfloat8",
          "low_vram": true
        },
        "sample": {
          "sampler": "flowmatch",
          "sample_every": 250,
          "width": 1024,
          "height": 1024,
          "guidance_scale": 4,
          "sample_steps": 30
        }
      }
    ]
  },
  "meta": {
    "name": "[name]",
    "version": "1.0",
    "description": "LoRA on Krea 2 (raw) with quantization + low_vram for 24GB cards. Natural-language captions. For Krea 2 Turbo, switch the arch to krea2:turbo in the UI so the training adapter is applied."
  }
}
