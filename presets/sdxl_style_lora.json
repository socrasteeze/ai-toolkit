{
  "job": "extension",
  "config": {
    "name": "preset",
    "process": [
      {
        "type": "diffusion_trainer",
        "training_folder": "output",
        "device": "cuda",
        "trigger_word": null,
        "network": {
          "type": "lora",
          "linear": 32,
          "linear_alpha": 32,
          "conv": 16,
          "conv_alpha": 16
        },
        "save": {
          "dtype": "bf16",
          "save_every": 250,
          "max_step_saves_to_keep": 4,
          "save_format": "safetensors",
          "push_to_hub": false
        },
        "datasets": [
          {
            "folder_path": "/path/to/images/folder",
            "caption_ext": "txt",
            "caption_dropout_rate": 0.1,
            "resolution": [1024],
            "num_repeats": 1,
            "cache_latents_to_disk": true
          }
        ],
        "train": {
          "batch_size": 1,
          "steps": 3000,
          "gradient_accumulation": 1,
          "train_unet": true,
          "train_text_encoder": false,
          "gradient_checkpointing": true,
          "noise_scheduler": "ddpm",
          "optimizer": "adamw8bit",
          "content_or_style": "style",
          "lr": 0.0001,
          "dtype": "bf16"
        },
        "model": {
          "name_or_path": "stabilityai/stable-diffusion-xl-base-1.0",
          "arch": "sdxl",
          "quantize": false,
          "quantize_te": false
        },
        "sample": {
          "sampler": "ddpm",
          "sample_every": 250,
          "width": 1024,
          "height": 1024,
          "guidance_scale": 6,
          "sample_steps": 25
        }
      }
    ]
  },
  "meta": {
    "name": "[name]",
    "version": "1.0",
    "description": "Style LoRA on base SDXL. Higher caption dropout and 'style' timestep weighting bias learning toward look/aesthetic over subject identity."
  }
}
