{
  "job": "extension",
  "config": {
    "name": "preset",
    "process": [
      {
        "type": "diffusion_trainer",
        "training_folder": "output",
        "device": "cuda",
        "trigger_word": null,
        "network": {
          "type": "lora",
          "linear": 32,
          "linear_alpha": 32
        },
        "save": {
          "dtype": "bf16",
          "save_every": 250,
          "max_step_saves_to_keep": 4,
          "save_format": "safetensors",
          "push_to_hub": false
        },
        "datasets": [
          {
            "folder_path": "/path/to/images/folder",
            "caption_ext": "txt",
            "caption_dropout_rate": 0.05,
            "resolution": [
              768,
              1024
            ],
            "num_repeats": 1,
            "cache_latents_to_disk": true
          }
        ],
        "train": {
          "batch_size": 1,
          "steps": 2500,
          "gradient_accumulation": 1,
          "train_unet": true,
          "train_text_encoder": false,
          "gradient_checkpointing": true,
          "noise_scheduler": "flowmatch",
          "optimizer": "adamw8bit",
          "timestep_type": "sigmoid",
          "content_or_style": "balanced",
          "lr": 0.0001,
          "dtype": "bf16"
        },
        "model": {
          "name_or_path": "Tongyi-MAI/Z-Image-Turbo",
          "arch": "zimage",
          "quantize": true,
          "qtype": "qfloat8",
          "quantize_te": true,
          "qtype_te": "qfloat8",
          "low_vram": true
        },
        "sample": {
          "sampler": "flowmatch",
          "sample_every": 250,
          "width": 1024,
          "height": 1024,
          "guidance_scale": 1,
          "sample_steps": 8
        }
      }
    ]
  },
  "meta": {
    "name": "[name]",
    "version": "1.0",
    "description": "Character LoRA on Z-Image Turbo (Tongyi-MAI/Z-Image-Turbo). Ported from LoRA Dataset Studio's researched built-in (rank 32/alpha 32 = community default, lower-regret for hard faces; sigmoid timesteps per Ostris' subject guidance). Prose captions with a unique trigger word. Steps: LDS computes ~120/image clamped [1500,3500] — 2500 here is the midpoint; scale to your set. Sample settings assume the distilled Turbo (CFG 1, 8 steps)."
  }
}
